# example tix config
# copy this file to:
#   ~/.config/tix/config.toml

# IANA timezone used for parsing and rendering local alarm times.
timezone = "Europe/Berlin"

# date parsing order for slash-separated dates.
# supported: dmy, mdy, ymd
date_order = "dmy"

# prefer the system locale when resolving ambiguous slash dates
# like 03/04/2026. unambiguous dates like 12/31/2026 still parse.
prefer_locale_date_order = true

# clock display style.
# supported: 24h, 12h
time_notation = "24h"

# default run mode when no CLI override is provided.
# supported: background, foreground
default_mode = "background"

# stop the alarm automatically after N seconds.
# use 0 to keep ringing until stopped manually.
auto_stop_seconds = 0

# volume in the inclusive range 0.0..=1.0.
volume = 0.20

# optional custom sound file.
# absolute paths are supported.
# relative paths are resolved from ~/.config/tix/
# set to "none" or remove the key to use the built-in tone fallback.
sound_file = "none"

[notifications]
# enable desktop notifications for background alarms.
enabled = true

# on Linux/XDG, clicking the notification body can stop the alarm.
# macOS ignores this because notify-rust action callbacks are not supported there.
clickable = true

# notification timeout in milliseconds.
# 0 means keep the notification open until the user dismisses it.
timeout_ms = 0

# on Linux/XDG, show an explicit Stop button next to the clickable body action.
# ignored when clickable = false and ignored on macOS.
show_stop_button = true

[foreground]
# minimum effective refresh interval is 100ms.
refresh_interval_ms = 250

# show the parsed input string.
show_input = true

# show the current local date/time.
show_current_datetime = true

# show the target alarm date/time.
show_target_datetime = true

# show the remaining time until trigger.
show_remaining = true

# remaining-time renderer.
# supported: digital, human
timer_style = "digital"
